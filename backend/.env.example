EIP_ENV=production
EIP_DATABASE_URL=postgresql://eip:eip-change-me@127.0.0.1:5432/eip
EIP_DATA_DIR=backend/data
EIP_APP_SECRET_KEY=change-me-in-production
EIP_ADMIN_USERNAME=admin
EIP_RUNTIME_ROLE=all
EIP_DISABLE_AUTOSCAN=0
EIP_ENABLE_SCHEDULER=1
EIP_SCAN_INTERVAL_SECONDS=900
EIP_BACKGROUND_HEARTBEAT_INTERVAL_SECONDS=30
EIP_TARGET_SCAN_WORKERS=4
EIP_SESSION_LIFETIME_HOURS=12
EIP_SECURE_COOKIES=1
EIP_COOKIE_SAMESITE=lax
EIP_ALLOWED_ORIGINS=https://access.example.com
EIP_TRUSTED_HOSTS=access.example.com
EIP_ENFORCE_CSRF=1
EIP_LOGIN_MAX_FAILURES=5
EIP_LOGIN_WINDOW_SECONDS=600
EIP_LOGIN_LOCKOUT_SECONDS=900
EIP_SNAPSHOT_RETENTION=25
EIP_ENABLE_MATERIALIZED_ACCESS_INDEX=1
# EIP_EXPOSE_BOOTSTRAP_DETAILS=0
# EIP_SSH_KNOWN_HOSTS=C:\ProgramData\ssh\ssh_known_hosts
# EIP_ALLOW_INSECURE_SSH_HOST_KEYS=0

# Optional telemetry
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318

# Optional enterprise search / cache / analytics
# EIP_OPENSEARCH_URL=http://127.0.0.1:9200
# EIP_OPENSEARCH_INDEX=eip-entities
# EIP_OPENSEARCH_VERIFY_TLS=0
# EIP_VALKEY_URL=redis://127.0.0.1:6379/0
# EIP_CLICKHOUSE_URL=http://127.0.0.1:8123
# EIP_CLICKHOUSE_DATABASE=eip
# EIP_CLICKHOUSE_VERIFY_TLS=0
# EIP_NEO4J_URI=bolt://127.0.0.1:7687
# EIP_NEO4J_USERNAME=neo4j
# EIP_NEO4J_PASSWORD=change-me
# EIP_KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
# EIP_TEMPORAL_ADDRESS=127.0.0.1:7233
# EIP_LANGFUSE_BASE_URL=http://127.0.0.1:3000

# Optional LDAP / Active Directory
# EIP_LDAP_SERVER_URI=ldaps://dc01.example.internal:636
# EIP_LDAP_BIND_DN=CN=eip-reader,OU=Service Accounts,DC=example,DC=internal
# EIP_LDAP_PASSWORD=super-secret
# EIP_LDAP_BASE_DN=DC=example,DC=internal
# EIP_LDAP_ENTRY_LIMIT=500

# Optional Microsoft Graph / Entra ID
# EIP_GRAPH_TENANT_ID=00000000-0000-0000-0000-000000000000
# EIP_GRAPH_CLIENT_ID=00000000-0000-0000-0000-000000000000
# EIP_GRAPH_CLIENT_SECRET=super-secret
# EIP_GRAPH_USER_LIMIT=200
# EIP_GRAPH_GROUP_LIMIT=200
# Graph site IDs contain commas, so separate multiple values with semicolons.
# EIP_GRAPH_SITE_IDS=tenant.sharepoint.com,siteCollectionId,webId;tenant.sharepoint.com,otherSiteCollectionId,otherWebId
# App permissions typically needed for the current runtime: User.Read.All, Group.Read.All, GroupMember.Read.All.
# Add Sites.FullControl.All only if EIP_GRAPH_SITE_IDS is enabled.

# Optional Azure RBAC
# EIP_AZURE_SUBSCRIPTION_IDS=11111111-1111-1111-1111-111111111111,22222222-2222-2222-2222-222222222222

# Optional Okta
# EIP_OKTA_BASE_URL=https://company.okta.com
# EIP_OKTA_API_TOKEN=super-secret
# EIP_OKTA_GROUP_LIMIT=200
# EIP_OKTA_USER_LIMIT=200

# Optional AWS IAM / Organizations
# EIP_AWS_ACCESS_KEY_ID=AKIA...
# EIP_AWS_SECRET_ACCESS_KEY=super-secret
# EIP_AWS_ACCOUNT_IDS=111111111111,222222222222

# Optional Google Workspace / Cloud Identity / Drive
# EIP_GOOGLE_CUSTOMER_ID=my_customer
# EIP_GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# EIP_GOOGLE_ADMIN_SUBJECT=admin@example.com

# Optional CyberArk
# EIP_CYBERARK_BASE_URL=https://pvwa.company.internal
# EIP_CYBERARK_USERNAME=api-user
# EIP_CYBERARK_PASSWORD=super-secret
# EIP_CYBERARK_AUTH_TYPE=cyberark
# EIP_CYBERARK_SAFE_LIMIT=100

# Optional SSH target secret examples for remote Linux collectors
# EIP_SSH_TARGET_PASSWORD=super-secret

# Optional self-hosted Keycloak OIDC provider example
# KEYCLOAK_CLIENT_SECRET=super-secret
