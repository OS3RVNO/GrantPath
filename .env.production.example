POSTGRES_DB=eip
POSTGRES_USER=eip
POSTGRES_PASSWORD=replace-with-a-strong-db-password

EIP_ADMIN_USERNAME=admin
EIP_APP_SECRET_KEY=replace-with-a-long-random-secret
EIP_RUNTIME_ROLE=all
EIP_BACKEND_RUNTIME_ROLE=all
EIP_ALLOWED_ORIGINS=https://access.example.com
EIP_TRUSTED_HOSTS=access.example.com
EIP_SECURE_COOKIES=1
EIP_EXPOSE_BOOTSTRAP_DETAILS=0
# Host path mounted read-only into the backend container as /scan-root.
EIP_SCAN_ROOT=/srv/eip/scan-root
EIP_ENABLE_MATERIALIZED_ACCESS_INDEX=1
EIP_SNAPSHOT_RETENTION=25
EIP_ENABLE_SCHEDULER=1
EIP_SCAN_INTERVAL_SECONDS=900
EIP_BACKGROUND_HEARTBEAT_INTERVAL_SECONDS=30
EIP_ALLOW_INSECURE_SSH_HOST_KEYS=0

# When you enable the worker-runner profile, set EIP_BACKEND_RUNTIME_ROLE=api for the backend
# and let the dedicated worker container own recurring scans and report scheduling.

# Optional enterprise search / cache / analytics / graph
# EIP_OPENSEARCH_URL=http://opensearch:9200
# EIP_OPENSEARCH_INDEX=eip-entities
# EIP_OPENSEARCH_VERIFY_TLS=0
# EIP_CLICKHOUSE_URL=http://clickhouse:8123
# EIP_CLICKHOUSE_DATABASE=eip
# EIP_CLICKHOUSE_VERIFY_TLS=0
# EIP_VALKEY_URL=redis://valkey:6379/0
# EIP_NEO4J_URI=bolt://neo4j:7687
# EIP_NEO4J_USERNAME=neo4j
# EIP_NEO4J_PASSWORD=change-me
# EIP_KAFKA_BOOTSTRAP_SERVERS=kafka:9092
# EIP_TEMPORAL_ADDRESS=temporal:7233
# EIP_LANGFUSE_BASE_URL=http://langfuse-web:3000

# Optional self-hosted SSO profile
KEYCLOAK_PORT=8080
KEYCLOAK_DB_SCHEMA=public
KEYCLOAK_BOOTSTRAP_ADMIN_USERNAME=kcadmin
KEYCLOAK_BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-keycloak-password

# Optional cloud connectors
# EIP_GRAPH_TENANT_ID=00000000-0000-0000-0000-000000000000
# EIP_GRAPH_CLIENT_ID=00000000-0000-0000-0000-000000000000
# EIP_GRAPH_CLIENT_SECRET=replace-with-a-graph-secret
# Graph site IDs contain commas, so separate multiple values with semicolons.
# EIP_GRAPH_SITE_IDS=tenant.sharepoint.com,siteCollectionId,webId;tenant.sharepoint.com,otherSiteCollectionId,otherWebId
# EIP_AZURE_SUBSCRIPTION_IDS=11111111-1111-1111-1111-111111111111
# EIP_OKTA_BASE_URL=https://company.okta.com
# EIP_OKTA_API_TOKEN=replace-with-an-okta-token
# EIP_AWS_ACCESS_KEY_ID=AKIA...
# EIP_AWS_SECRET_ACCESS_KEY=replace-with-an-aws-secret
# EIP_AWS_ACCOUNT_IDS=111111111111,222222222222
# EIP_GOOGLE_CUSTOMER_ID=my_customer
# EIP_GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# EIP_GOOGLE_ADMIN_SUBJECT=admin@example.com
